---
const { title, desc, icon: IconComponent } = Astro.props;
---
<div class="flex items-start gap-4 p-5 bg-white/5 border border-white/10 rounded-2xl hover:bg-white/10 transition-colors">
  
  <!-- Icon -->
  <div class="shrink-0 text-[#c9a84c]">
    <!-- Render the component reference -->
    <IconComponent class="w-6 h-6" />
  </div>

  <!-- Text -->
  <div class="flex-1 min-w-0">
    <h3 class="text-white text-lg font-medium truncate">{title}</h3>
    <p class="text-white/40 text-sm mt-1">{desc}</p>
  </div>
</div>