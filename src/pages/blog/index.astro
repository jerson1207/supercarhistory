---
import Layout from '../../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

// Fetch all posts - Astro handles this at build time
const allPosts = await getCollection('blog');

// Sort by date (Newest first)
const sortedArticles = allPosts.sort((a, b) => 
  b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const uniqueCategories: string[] = [
  "All",
  ...new Set<string>(allPosts.map((post) => post.data.category))
];

const featured = sortedArticles.find((post) => post.data.featured) || sortedArticles[0];
---

<Layout 
  title="Supercar History | Legendary Stories & Specs" 
  description="Explore the world's most iconic supercars, technical deep-dives, and investment insights."
>
  <div class="min-h-screen bg-[#0a0a0a] pt-28 pb-20 text-center">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="mb-10 text-left">
        <p class="text-[#c9a84c] text-xs tracking-[0.3em] uppercase mb-2">Stories & Histories</p>
        <h1 class="text-white text-4xl md:text-5xl font-extralight tracking-tight mb-3">
          Hot <span class="text-[#c9a84c]">Topics</span>
        </h1>
        <p class="text-white/30 text-sm">The untold stories behind the world's greatest supercars</p>
      </div>
      
      <div id="category-buttons" class="flex flex-wrap gap-2 mb-10">
        {uniqueCategories.map((cat) => (
          <button
            class="category-button px-4 py-1.5 rounded-full text-[10px] tracking-widest uppercase transition-colors border border-white/10 text-white/30 bg-white/5 hover:text-white/60 cursor-pointer"
            data-category={cat}
            >
            {cat}
            </button>
        ))}
      </div>
    
      {featured && (
        <a 
          href={`/blog/${featured.id}`} 
          id="featured-article"
          class="w-full mb-10 rounded-2xl overflow-hidden relative group text-left block border border-white/5" 
        >
          <div class="w-full h-80 md:h-105 bg-cover bg-center transition-transform duration-700 group-hover:scale-105" style={`background-image: url('${featured.data.imgURL}')`}></div>
          <div class="absolute inset-0 bg-linear-to-t from-black/90 via-black/40 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-8">
             <span class="px-3 py-1 bg-[#c9a84c] text-black text-[9px] tracking-widest uppercase rounded-full font-medium mb-3 inline-block">Featured</span>
             <h2 class="text-white text-2xl md:text-3xl font-extralight leading-tight mb-3 max-w-2xl">{featured.data.title}</h2>
             <div class="flex items-center gap-2 text-[#c9a84c] text-xs tracking-widest uppercase">Read Story →</div>
          </div>
        </a>
      )}

      <div id="article-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 w-full">
        {sortedArticles.map((article: CollectionEntry<'blog'>) => (
          <a
            href={`/blog/${article.id}`}
            class="article-card text-left rounded-2xl overflow-hidden border border-white/8 bg-[#0f0f0f] hover:border-[#c9a84c]/25 transition-all duration-300 group block"
            data-category={article.data.category}
          >
            <div class="w-full h-48 bg-cover bg-center transition-transform duration-500 group-hover:scale-105" style={`background-image: url('${article.data.imgURL}')`}></div>
            <div class="p-5">
              <span class="text-[#c9a84c] text-[9px] tracking-widest uppercase mb-2 block">{article.data.category}</span>
              <h3 class="text-white text-sm font-light leading-snug mb-3 group-hover:text-[#c9a84c] transition-colors">{article.data.title}</h3>
              <p class="text-white/35 text-xs line-clamp-3 mb-4">{article.data.description}</p>
              <div class="flex items-center justify-between pt-4 border-t border-white/5 text-[10px]">
                <span class="text-white/20">{article.data.readTime}</span>
                <span class="text-[#c9a84c]/60 uppercase tracking-widest">Read Story →</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <nav id="pagination-nav" class="flex flex-col items-center gap-6 mt-20 border-t border-white/5 pt-12">
        <div class="flex items-center gap-8">
          <button id="prev-btn" class="p-2 text-white/20 hover:text-[#c9a84c] disabled:opacity-0 transition-all cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          </button>

          <div id="page-numbers" class="flex items-center gap-4">
            </div>

          <button id="next-btn" class="p-2 text-white/20 hover:text-[#c9a84c] disabled:opacity-0 transition-all cursor-pointer disabled:cursor-not-allowed">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="m9 18 6-6-6-6"/>
            </svg>
          </button>
        </div>
      </nav>

    </div>
  </div>
</Layout>

<script is:inline>
  const buttons = document.querySelectorAll(".category-button");
  const featuredArticle = document.getElementById("featured-article");
  const articleCards = Array.from(document.querySelectorAll(".article-card"));
  const prevBtn = document.getElementById("prev-btn");
  const nextBtn = document.getElementById("next-btn");
  const pageNumbersContainer = document.getElementById("page-numbers");
  const paginationNav = document.getElementById("pagination-nav");

  let selectedCategory = "All";
  let currentPage = 1;
  const itemsPerPage = 9;

  function updateUI() {
    // 1. Filter articles by category
    const filtered = articleCards.filter(card => {
      const cat = card.getAttribute("data-category");
      return selectedCategory === "All" || cat === selectedCategory;
    });

    // 2. Featured visibility
    if (featuredArticle) {
      featuredArticle.style.display = (selectedCategory === "All" && currentPage === 1) ? "block" : "none";
    }

    // 3. Page Calculations
    const totalPages = Math.ceil(filtered.length / itemsPerPage) || 1;
    if (currentPage > totalPages) currentPage = totalPages;

    const start = (currentPage - 1) * itemsPerPage;
    const end = start + itemsPerPage;

    // 4. Update Article Visibility with STAGGERED DELAY
    articleCards.forEach(c => {
      c.classList.remove("is-visible"); // Hide all first
      c.style.display = "none";
    });

    const visibleArticles = filtered.slice(start, end);

    visibleArticles.forEach((card, idx) => {
      card.style.display = "block";
      
      // Create the delay effect (50ms * index)
      setTimeout(() => {
        card.classList.add("is-visible");
      }, idx * 50); 
    });

    // 5. Generate Brackets [01]
    pageNumbersContainer.innerHTML = ''; 
    for (let i = 1; i <= totalPages; i++) {
      const btn = document.createElement('button');
      const isCurrent = i === currentPage;
      const displayNum = i.toString().padStart(2, '0');
      btn.textContent = isCurrent ? `[${displayNum}]` : displayNum;
      btn.className = `text-[11px] tracking-[0.2em] font-medium transition-all duration-300 cursor-pointer ${isCurrent ? 'text-[#c9a84c] scale-110' : 'text-white/20 hover:text-white/60'}`;
      btn.onclick = () => {
        currentPage = i;
        window.scrollTo({ top: 0, behavior: 'smooth' });
        updateUI();
      };
      pageNumbersContainer.appendChild(btn);
    }

    // 6. Navigation Controls
    prevBtn.disabled = currentPage === 1;
    nextBtn.disabled = currentPage === totalPages;
    paginationNav.style.visibility = totalPages <= 1 ? "hidden" : "visible";

    // 7. Button Styles
    buttons.forEach(btn => {
    const isMatch = btn.getAttribute("data-category") === selectedCategory;
    
    if (isMatch) {
        // ACTIVE GOLD STATE
        btn.classList.add("bg-[#c9a84c]/15", "border-[#c9a84c]/40", "text-[#c9a84c]");
        btn.classList.remove("bg-white/5", "border-white/10", "text-white/30");
    } else {
        // INACTIVE GHOST STATE
        btn.classList.remove("bg-[#c9a84c]/15", "border-[#c9a84c]/40", "text-[#c9a84c]");
        btn.classList.add("bg-white/5", "border-white/10", "text-white/30");
    }
    });
  }

  // Listeners
  buttons.forEach(btn => btn.addEventListener("click", () => {
    selectedCategory = btn.getAttribute("data-category");
    currentPage = 1;
    updateUI();
  }));

  prevBtn.addEventListener("click", () => {
    if (currentPage > 1) { currentPage--; updateUI(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
  });

  nextBtn.addEventListener("click", () => {
    const total = Math.ceil(articleCards.filter(c => selectedCategory === "All" || c.getAttribute("data-category") === selectedCategory).length / itemsPerPage);
    if (currentPage < total) { currentPage++; updateUI(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
  });

  window.scrollTo({
    top: 0,
    behavior: 'smooth'
  });

  updateUI();
</script>

<style is:global>
  /* The initial state: hidden and slightly lower */
  .article-card {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  /* The visible state */
  .article-card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Smooth fade for the featured article */
  #featured-article {
    transition: opacity 0.8s ease;
  }
</style>