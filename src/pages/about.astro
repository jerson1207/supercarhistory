---
import Layout from '../layouts/Layout.astro';
import InfoCard from '../components/InfoCard.astro';

// Import SVGs from assets as components
import BrainIcon from '../assets/icons/brain.svg';
import SpeedometerIcon from '../assets/icons/speedometer.svg';
import CubeIcon from '../assets/icons/cube.svg';

const features = [
  {
    title: "AI-Powered Visuals",
    desc: "All images are AI-generated or license-free, ensuring authenticity without copyright issues.",
    icon: BrainIcon,
  },
  {
    title: "Accurate Specs",
    desc: "Performance data, specifications, and historical details are verified using trusted automotive archives and manufacturer records.",
    icon: SpeedometerIcon,
  },
  {
    title: "3D Exploration",
    desc: "Interactive 3D models allow you to examine legendary cars from every angle in your browser.",
    icon: CubeIcon,
  },
];
---
<Layout>
  <div class="min-h-screen bg-[#0a0a0a] pt-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Mission Section -->
      <div class="mb-16">
        <p class="text-[#c9a84c] text-xs tracking-[0.3em] uppercase mb-3">Our Mission</p>
        <h1 class="text-white text-4xl md:text-5xl font-extralight tracking-tight leading-tight mb-6">
          Documenting the History<br />of Iconic Supercars
        </h1>
        <p class="text-white/50 text-lg leading-relaxed max-w-2xl">
          SupercarHistory is dedicated to preserving and sharing the stories behind the world's most legendary supercars.
        </p>
      </div>

      <!-- Features Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
        {features.map((f) => (
          <InfoCard title={f.title} desc={f.desc} icon={f.icon} />
        ))}
      </div>


      <div class="border border-white/10 rounded-2xl p-8 mb-16">
        <h2 class="text-white text-xl font-light mb-4">Advertising Disclosure</h2>
        <p class="text-white/50 text-sm leading-relaxed">
          SupercarHistory is supported by Google AdSense advertisements. Ads are clearly labeled and do not influence editorial content. 
          We provide unbiased and accurate information about iconic supercars. Revenue from ads helps maintain and improve this free resource.
        </p>
      </div>

        
      <div class="border border-white/10 rounded-2xl p-8 mb-20">
        <h2 class="text-white text-xl font-light mb-2">Get in Touch</h2>
        <p class="text-white/50 text-sm mb-6">
          Interested in contributing, collaborating, or reporting an inaccuracy? We’d love to hear from you.
        </p>
  
        <div class="flex flex-col gap-4">
          <a
            href="mailto:hello@supercarhistory.com"
            class="inline-flex items-center gap-3 text-[#c9a84c] hover:text-[#d4b86a] transition-colors group"
          >
            <span class="p-2 bg-[#c9a84c]/10 rounded-lg group-hover:bg-[#c9a84c]/20">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </span>
            <span class="text-sm font-medium">hello@supercarhistory.com</span>
          </a>

          <div class="flex items-center gap-3 text-white/40">
            <span class="p-2 bg-white/5 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </span>
            <span class="text-xs uppercase tracking-wider">Manila City, Philippines</span>
          </div>
        </div>

        <div class="mt-8">
          <a
            href="mailto:hello@supercarhistory.com"
            class="inline-flex items-center justify-center bg-[#c9a84c] text-black px-8 py-3 rounded-full text-sm font-bold hover:bg-[#d4b86a] transform hover:scale-[1.02] transition-all"
          >
            Send us a Message
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>