---
import Layout from '../../layouts/Layout.astro';
import { carsData } from '../../data/cars';
import SpecCard from '../../components/SpecCard.astro';
import AdBanner from '../../components/AdBanner.astro';
import ZapIcon from '../../assets/icons/zap.svg';
import GaugeIcon from '../../assets/icons/speedometer.svg';
import TimerIcon from '../../assets/icons/timer.svg';
import GlobeIcon from '../../assets/icons/globe.svg';
import Sparkles from '../../assets/icons/sparkles.svg';
import Star from '../../assets/icons/star.svg';
import Trophy from '../../assets/icons/trophy.svg';
import Film from '../../assets/icons/film.svg';

import DetailItem from '../../components/DetailItem.astro';

export async function getStaticPaths() {
  return carsData.map(car => ({
    params: { slug: car.id },
    props: { car },
  }));
}

const { car } = Astro.props;

if (!car) {
  return Astro.redirect('/404');
}
---

<Layout title={`${car.name} Specs, Top Speed, 0-60, Engine & History`} description={car.description}>
  <div class="min-h-screen bg-[#0a0a0a]">
    <div class="relative h-[60vh] min-h-100 overflow-hidden">
      <img
        src={car.imgURL}
        alt={car.name}
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-linear-to-t from-[#0a0a0a] via-[#0a0a0a]/40 to-transparent"></div>
      
      <div class="absolute bottom-0 left-0 right-0 px-6 md:px-12 pb-10 flex items-end justify-between">
        <div>
          <p class="text-[#c9a84c] text-xs tracking-[0.3em] uppercase mb-2">{car.brand} · {car.era}</p>
          <h1 class="text-white text-4xl md:text-6xl font-extralight tracking-tight">{car.name}</h1>
          <p class="text-white/50 mt-2 text-lg">{car.year}</p>
        </div>
      </div>
    </div>

    <div class="max-w-6xl mx-auto px-6 py-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
        <SpecCard icon={ZapIcon.src} label="Horsepower" value={`${car.horsepower} hp`} />
        <SpecCard icon={GaugeIcon.src} label="Top Speed" value={`${car.topSpeed} mph`} />
        <SpecCard icon={TimerIcon.src} label="0–60 mph" value={car.acceleration} />
        <SpecCard icon={GlobeIcon.src} label="Origin" value={car.country} />
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
        <div>
          <p class="text-white/40 text-xs tracking-[0.3em] uppercase mb-4">{car.name} Visualizer</p>
          <div class="aspect-video bg-white/5 border border-white/10 rounded-2xl flex items-center justify-center text-white/20">
             3D Model coming soon
          </div>
        </div>
  
        <div>
          <p class="text-white/40 text-xs tracking-[0.3em] uppercase mb-4">About</p>
          <p class="text-white/70 leading-relaxed text-base">{car.description}</p>
          <div class="mt-6 grid grid-cols-2 gap-4">
            <DetailItem label="Engine" value={car.engine} />
            <DetailItem label="Production" value={car.production} />
            <DetailItem label="Designer" value={car.designer} />
            <DetailItem label="Country" value={car.country} />
          </div>
        </div>
      </div>

      <AdBanner />

      <div class="mt-12">
        <div class="flex gap-6 border-b border-white/10 mb-8 overflow-x-auto">
          {["history", "fun facts", "legendary", "awards", "media"].map((tab) => (
            <button
              data-tab-target={tab}
              class="tab-btn pb-3 text-sm uppercase tracking-widest transition-all text-white/30 hover:text-white/60 whitespace-nowrap"
            >
              {tab}
            </button>
          ))}
        </div>

        <div class="tab-content-container">
          <div data-tab-content="history" class="tab-pane active">
            <div class="space-y-6">
              {car.history.map((milestone, i) => (
                <div class="flex gap-4">
                  <div class="flex flex-col items-center">
                    <div class="w-2.5 h-2.5 rounded-full bg-[#c9a84c] mt-1.5 shrink-0 shadow-[0_0_10px_rgba(201,168,76,0.5)]" />
                    {i < car.history.length - 1 && <div class="w-px flex-1 bg-white/10 mt-2" />}
                  </div>
                  <p class="text-white/70 pb-6 leading-relaxed text-sm md:text-base">{milestone}</p>
                </div>
              ))}
            </div>
          </div>

          <div data-tab-content="fun facts" class="tab-pane">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {(car.funFacts || []).map((fact) => (
                <div class="flex items-start gap-3 bg-white/3 border border-white/8 rounded-xl p-4">
                  <img src={Sparkles.src} class="w-4 h-4 mt-1 icon-gold" alt="" />
                  <p class="text-white/70 text-sm leading-relaxed">{fact}</p>
                </div>
              ))}
            </div>
          </div>

          <div data-tab-content="legendary" class="tab-pane">
            <div class="bg-white/3 border border-[#c9a84c]/20 rounded-2xl p-8 relative overflow-hidden">
              <div class="flex items-center gap-3 mb-5">
                <img src={Star.src} class="w-5 h-5 icon-gold" alt="" />
                <p class="text-[#c9a84c] text-xs tracking-[0.3em] uppercase">Why It's Legendary</p>
              </div>
              <p class="text-white/80 leading-relaxed text-lg italic font-light">
                "{car.legendary || "The legend speaks for itself."}"
              </p>
            </div>
          </div>

          <div data-tab-content="awards" class="tab-pane">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {(car.awards || []).map((award) => (
                <div class="flex items-start gap-3 bg-white/3 border border-white/8 rounded-xl p-4">
                  <img src={Trophy.src} class="w-4 h-4 mt-0.5 icon-gold" alt="" />
                  <p class="text-white/70 text-sm">{award}</p>
                </div>
              ))}
            </div>
          </div>

          <div data-tab-content="media" class="tab-pane">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {(car.media || []).map((item) => (
                <div class="flex items-start gap-3 bg-white/3 border border-white/8 rounded-xl p-4">
                  <img src={Film.src} class="w-4 h-4 mt-0.5 icon-gold" alt="" />
                  <p class="text-white/70 text-sm">{item}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .tab-pane {
    display: none;
  }
  .tab-pane.active {
    display: block;
    animation: fadeIn 0.4s ease-out;
  }
  .tab-btn.active {
    color: #c9a84c;
    border-bottom: 2px solid #c9a84c;
  }
  .icon-gold {
    filter: invert(78%) sepia(21%) saturate(972%) hue-rotate(5deg) brightness(92%) contrast(85%);
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  const tabs = document.querySelectorAll('.tab-btn');
  const panes = document.querySelectorAll('.tab-pane');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('data-tab-target');
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      panes.forEach(pane => {
        pane.classList.toggle('active', pane.getAttribute('data-tab-content') === target);
      });
    });
  });

  // Default to first tab
  tabs[0]?.classList.add('active');
</script>