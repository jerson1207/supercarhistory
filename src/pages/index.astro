---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import AdBanner from '../components/AdBanner.astro';
import SearchFilter from '../components/SearchFilter.astro';
import EraSection from '../components/EraSection.astro';
import { carsData, eras } from "../data/cars";
---

<Layout>
    <Hero />
    <AdBanner />
    <SearchFilter />

    <div id="default-results">
        <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20 text-red-600">
            <h2 class="text-white text-2xl font-light tracking-widest mb-8 uppercase">
                All Cars <span class="text-[#c9a84c]">({carsData.length})</span>
            </h2>

            {eras.map((era) => (
                <EraSection era={era} cars={carsData.filter(c => c.era === era)} />
            ))}
        </section>
    </div>

    <div id="filter-results-container" class="hidden max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
        <h2 class="text-white text-2xl font-light tracking-widest mb-8 uppercase">
            Filtered Results <span id="filter-count" class="text-[#c9a84c]">(0)</span>
        </h2>
        <div id="results-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
		</div>
    </div>
</Layout>

<script is:inline define:vars={{ carsData }}>
  // Now 'carsData' is available inside the script!
  
  const searchInput = document.getElementById('searchInput');
  const brandSelect = document.getElementById('brandSelect');
  const eraSelect = document.getElementById('eraSelect');
  const clearBtn = document.getElementById('clearFilters');
  
  const defaultView = document.getElementById('default-results');
  const filterView = document.getElementById('filter-results-container');
  const resultsGrid = document.getElementById('results-grid');
  const filterCount = document.getElementById('filter-count');

  const triggerFilter = () => {
    const query = searchInput.value.toLowerCase();
    const brand = brandSelect.value;
    const era = eraSelect.value;

    const isFiltered = query || brand || era;

    if (!isFiltered) {
        defaultView.classList.remove('hidden');
        filterView.classList.add('hidden');
        clearBtn.style.display = 'none';
        return;
    }

    // Show filtered view, hide default
    defaultView.classList.add('hidden');
    filterView.classList.remove('hidden');
    clearBtn.style.display = 'flex';

    // Filter Logic
    const filteredCars = carsData.filter(car => {
        const matchesSearch = car.name.toLowerCase().includes(query);
        const matchesBrand = brand ? car.brand === brand : true;
        const matchesEra = era ? car.era === era : true;
        return matchesSearch && matchesBrand && matchesEra;
    });

    // Update UI
    filterCount.innerText = `(${filteredCars.length})`;
    
    // Render Cards
    resultsGrid.innerHTML = filteredCars.map(car => `			
		<a
			href="#"
			class="group block bg-white/3 border border-white rounded-2xl overflow-hidden hover:border-[#c9a84c]/40 transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-[#c9a84c]/5"
		>
			<div class="relative overflow-hidden h-48">
			<img
				src="${car.imgURL || ''}"
				alt="${car.name || ''}"
				class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
				loading="lazy"
			/>
			<div class="absolute inset-0 bg-linear-to-t from-black/60 to-transparent"></div>
			<div class="absolute top-3 left-3">
				<span class="bg-black/60 backdrop-blur-sm text-[#c9a84c] text-xs px-2.5 py-1 rounded-full border border-[#c9a84c]/30 tracking-wider uppercase">
				${car.era || ''}
				</span>
			</div>
			<div class="absolute bottom-3 right-3">
				<span class="bg-black/60 backdrop-blur-sm text-white/60 text-xs px-2.5 py-1 rounded-full">
				${car.type || ''}
				</span>
			</div>
			</div>

			<div class="p-5">
			<p class="text-white/40 text-xs tracking-widest uppercase mb-1">${car.brand || ''}</p>
			<h3 class="text-white text-lg font-light leading-tight mb-1">${car.name || ''}</h3>
			<p class="text-white/30 text-xs mb-4">${car.year || ''}</p>

			<div class="flex items-center justify-between pt-4 border-t border-white/8">
				<div class="flex items-center gap-1.5 text-white/60">
				<span class="text-sm font-medium text-white">${car.horsepower || ''}</span>
				<span class="text-xs text-white/30">hp</span>
				</div>
				<div class="flex items-center gap-1.5 text-white/60">
				<span class="text-sm font-medium text-white">${car.topSpeed || ''}</span>
				<span class="text-xs text-white/30">mph</span>
				</div>
				<div class="text-right">
				<span class="text-sm font-medium text-white">${car.acceleration || ''}</span>
				<span class="text-xs text-white/30 ml-1">0-60</span>
				</div>
			</div>
			</div>
		</a>
		`).join('');
  };

  // Event Listeners
  searchInput.addEventListener('input', triggerFilter);
  brandSelect.addEventListener('change', triggerFilter);
  eraSelect.addEventListener('change', triggerFilter);
  clearBtn.addEventListener('click', () => {
    searchInput.value = '';
    brandSelect.value = '';
    eraSelect.value = '';
    triggerFilter();
  });
</script>