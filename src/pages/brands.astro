---
import Layout from '../layouts/Layout.astro';
import { brandsData } from '../data/brandsdata.js';
import Calendar from '../assets/icons/calendar.svg';
import MapPin from '../assets/icons/map-pin.svg';
import ArrowRight from '../assets/icons/arrow-right.svg';
import Map from '../assets/icons/map.svg';

---

<Layout 
  title="Supercar Brands – Lamborghini, Ferrari, Porsche & More | SupercarHistory" 
  description="Explore the world’s most iconic supercar brands. Learn about Lamborghini, Ferrari, Porsche, and other legendary manufacturers, their history, and signature vehicles."
>
  <div class="min-h-screen bg-[#0a0a0a] justify-center pt-28 pb-24"> 
    <div class="max-w-6xl mx-auto px-6">
      {/* Header */}
      <div class="mb-16">
        <p class="text-[#c9a84c] text-xs tracking-[0.3em] uppercase mb-3">Heritage</p>
        <h1 class="text-white text-4xl md:text-5xl font-extralight tracking-tight mb-4">
          Iconic <span class="text-[#c9a84c]">Brands</span>
        </h1>
        <p class="text-white/30 text-sm max-w-xl">
          The manufacturers who defined what a supercar could be. Each brand a story of obsession, engineering genius, and automotive legend.
        </p>
        <div class="mt-6 h-px bg-linear-to-r from-[#c9a84c]/30 to-transparent" />
      </div>
      {/* Brands Grid */}
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {brandsData.map((brand) => (
          <a 
            href={`/brands/${brand.slug}`}
            class="group relative overflow-hidden rounded-2xl border border-white/60 bg-white/5 hover:border-[#c9a84c]/30 transition-all duration-500">
             <div class="relative h-44 overflow-hidden">
              {/* image */}
              <img
                  src={brand.heroImage}
                  alt={brand.name}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                />
              <div class="absolute inset-0 bg-linear-to-t from-[#0a0a0a] via-black/40 to-transparent" />
                <div class="absolute bottom-4 left-4">
                  {/* <p class="text-[#c9a84c] text-xs tracking-widest uppercase">{brand.country}</p> */}
                  <h2 class="text-white text-2xl font-extralight tracking-wide">{brand.name}</h2>
                </div>
             </div>

             {/* Info */}
              <div class="p-5">
                <p class="text-white/40 text-xs italic mb-4 line-clamp-2">"{brand.tagline}"</p>
                <div class="flex items-center gap-4 mb-4">
                  <div class="flex items-center gap-1.5 text-white/30 text-xs">
                    <Calendar class="w-4 h-4" />
                    <span>Est. {brand.founded}</span>
                  </div>
                  <div class="flex items-center gap-1.5 text-white/30 text-xs">
                    <MapPin class="w-4 h-4" />
                    <span>{brand.headquarters.split(",")[0]}</span>
                  </div>
                  <div class="flex items-center gap-1.5 text-white/30 text-xs">
                    <Map class="w-4 h-4" />
                    <span>{brand.country}</span>
                  </div>
                </div>
                <div class="flex items-center gap-1.5 text-[#c9a84c]/60 group-hover:text-[#c9a84c] text-xs tracking-widest uppercase transition-colors">
                  <span>Explore History</span>
                  <ArrowRight class="group-hover:translate-x-1 transition-transform w-4 h-4" />
                </div>
              </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>

<style>
  /* Subtle entrance animation */
  div {
    animation: fadeInUp 0.8s ease-out forwards;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>